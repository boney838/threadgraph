generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password_hash          String
  anthropic_key_encrypted String?
  anthropic_key_iv        String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  sessions Session[]
  graphs   Graph[]
  jobs     Job[]

  @@map("users")
}

model Session {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Graph {
  id              String   @id @default(cuid())
  user_id         String
  title           String
  source_platform String
  source_url      String?
  raw_turns        Json
  graph_json       Json
  usage_json       Json?
  pipeline_version String  @default("1.0.0")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("graphs")
}

model Job {
  id            String   @id @default(cuid())
  user_id       String
  graph_id      String?
  status        String   @default("queued")
  error_message String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  graph Graph? @relation(fields: [graph_id], references: [id])

  @@map("jobs")
}
